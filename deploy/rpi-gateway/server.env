# Ferrite Server environment — RPi gateway deployment
# Authentication: Basic auth (no Keycloak on edge)
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=changeme

# Ingest API key — devices/gateway must send this in X-API-Key header
INGEST_API_KEY=ferrite-fleet-demo-key

# CORS: restrict to local dashboard only
# CORS_ALLOWED_ORIGINS=http://localhost:4000
