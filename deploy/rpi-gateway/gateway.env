# Ferrite Gateway environment — RPi deployment
FERRITE_SERVER_URL=http://127.0.0.1:4000
INGEST_API_KEY=ferrite-fleet-demo-key
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=changeme

# USB transport — comma-separated list of serial ports
# Uses udev symlinks from 99-ferrite.rules for stable naming
USB_PORTS=/dev/ferrite-nucleo-l4,/dev/ferrite-nucleo-wl
USB_BAUD=115200

# Offline buffer
GATEWAY_BUFFER_DB=/opt/ferrite/data/gateway-buffer.db
GATEWAY_MAX_RETRIES=5
