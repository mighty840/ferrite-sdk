# ferrite-server environment configuration
# Copy to .env and modify as needed.

# --- Authentication Mode ---
# If all three KEYCLOAK_* variables are set, Keycloak OIDC is used.
# Otherwise, falls back to Basic auth.

# Keycloak OIDC (optional)
# KEYCLOAK_URL=http://localhost:8080
# KEYCLOAK_REALM=ferrite
# KEYCLOAK_CLIENT_ID=ferrite-dashboard
# KEYCLOAK_CLIENT_SECRET=

# Basic auth fallback (defaults: admin/admin)
# BASIC_AUTH_USER=admin
# BASIC_AUTH_PASS=admin

# --- Ingest API Key (optional) ---
# If set, device ingest endpoints require X-API-Key header.
# INGEST_API_KEY=
